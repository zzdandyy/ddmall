<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="pro.doublez.ddmall.service.goods.dao.CategoryMapper">

    <select id="findList" parameterType="pro.doublez.ddmall.goods.pojo.Category"
            resultType="pro.doublez.ddmall.goods.pojo.Category">
        select *
        from tb_category
        where 1 = 1
        <if test="name != null">
            and name = #{name}
        </if>
        <if test="goodsNum != null">
            and goods_num = #{goodsNum}
        </if>
        <if test="isShow != null">
            and is_show = #{isShow}
        </if>
        <if test="isMenu != null">
            and is_menu = #{isMenu}
        </if>
        <if test="seq != null">
            and seq = #{seq}
        </if>
        <if test="parentId != null">
            and parent_id  = #{parentId}
        </if>
        <if test="templateId != null">
            and template_id = #{templateId}
        </if>
    </select>

    <select id="findById" resultType="pro.doublez.ddmall.goods.pojo.Category" parameterType="java.lang.Integer">
        select *
        from tb_category
        where id = #{id}
    </select>

    <insert id="add" parameterType="pro.doublez.ddmall.goods.pojo.Category">
        insert into tb_category
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="name != null">
                name
            </if>
            <if test="goodsNum != null">
                goods_num
            </if>
            <if test="isShow != null">
                is_show
            </if>
            <if test="isMenu != null">
                is_menu
            </if>
            <if test="seq != null">
                seq
            </if>
            <if test="parentId != null">
                parent_id
            </if>
            <if test="templateId != null">
                template_id
            </if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="name != null">
                #{name}
            </if>
            <if test="goodsNum != null">
                #{goodsNum}
            </if>
            <if test="isShow != null">
                #{isShow}
            </if>
            <if test="isMenu != null">
                #{isMenu}
            </if>
            <if test="seq != null">
                #{seq}
            </if>
            <if test="parentId != null">
                #{parentId}
            </if>
            <if test="templateId != null">
                #{templateId}
            </if>
        </trim>
    </insert>

    <update id="update" parameterType="pro.doublez.ddmall.goods.pojo.Category">
        update tb_category
        <set>
            <if test="name != null">
                name=#{name}
            </if>
            <if test="goodsNum != null">
                goods_num =#{goodsNum}
            </if>
            <if test="isShow != null">
                is_show= #{isShow}
            </if>
            <if test="isMenu != null">
                is_menu =#{isMenu}
            </if>
            <if test="seq != null">
                seq = #{seq}
            </if>
            <if test="parentId != null">
                parent_id =#{parentId}
            </if>
            <if test="templateId != null">
                template_id = #{templateId}
            </if>
        </set>
        where id = #{id}
    </update>

    <update id="delete" parameterType="java.lang.Integer">
        delete
        from tb_category
        where id = #{id}
    </update>

</mapper>